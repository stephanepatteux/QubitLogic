{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>\n" | safeHTML -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
{{- range .Site.Pages }}
  {{- $skip := in (slice "taxonomy" "term" "sitemap") .Kind -}}
  {{- $skip = or $skip (eq .RelPermalink "/search/") -}}
  {{- $skip = or $skip (hasPrefix .RelPermalink "/page/") -}}
  {{- $skip = or $skip .Params.sitemap.disable -}}
  {{- if not $skip }}
  <url>
    <loc>{{ .Permalink }}</loc>{{ if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02" }}</lastmod>{{ end }}{{ if eq .Kind "home" }}
    <changefreq>daily</changefreq>
    <priority>1.0</priority>{{ else if eq .Kind "section" }}
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>{{ else if eq .Kind "page" }}
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>{{ end }}
  </url>
  {{- end }}
{{- end }}
</urlset>
